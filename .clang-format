BasedOnStyle: LLVM
IndentWidth: 4
ColumnLimit: 0
AllowShortIfStatementsOnASingleLine: false
AllowShortLoopsOnASingleLine: false
BraceWrapping:
  AfterFunction: true
  AfterNamespace: true
  AfterClass: true
  AfterStruct: true
  AfterEnum: true
  AfterControlStatement: Always
NamespaceIndentation: All